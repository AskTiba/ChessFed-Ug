// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("PLAYER")
  accounts      Account[]
  sessions      Session[]
  
  playerId      String?   @unique
  player        Player?   @relation(fields: [playerId], references: [id])
}

enum Role {
  PLAYER
  ADMIN
  OFFICIAL
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Player {
  id              String           @id @default(cuid())
  fideId          String?          @unique
  name            String
  rating          Int              @default(1200)
  federation      String           @default("UGA")
  clubId          String?
  club            Club?            @relation(fields: [clubId], references: [id])
  tournaments     Tournament[]
  whiteGames      Game[]           @relation("white_games")
  blackGames      Game[]           @relation("black_games")
  whiteMatchGames MatchGame[]      @relation("WhiteMatchPlayer")
  blackMatchGames MatchGame[]      @relation("BlackMatchPlayer")
  scores          Score[]
  grandPrixPoints GrandPrixPoint[]
  user            User?
}

model Club {
  id          String   @id @default(cuid())
  name        String
  owner       String?
  captain     String?
  founded     Int?
  description String?
  logo        String?
  players     Player[]
  standings   LeagueStanding[]
  homeMatches LeagueMatch[] @relation("HomeClub")
  awayMatches LeagueMatch[] @relation("AwayClub")
}

model LeagueMatch {
  id          String      @id @default(cuid())
  date        DateTime    @default(now())
  homeClubId  String
  awayClubId  String
  homeClub    Club        @relation("HomeClub", fields: [homeClubId], references: [id])
  awayClub    Club        @relation("AwayClub", fields: [awayClubId], references: [id])
  games       MatchGame[]
  status      String      @default("SCHEDULED") // SCHEDULED, LIVE, COMPLETED
}

model MatchGame {
  id            String      @id @default(cuid())
  matchId       String
  match         LeagueMatch @relation(fields: [matchId], references: [id])
  type          GameType    @default(CLASSICAL)
  whitePlayerId String
  blackPlayerId String
  result        String?     // "1-0", "0-1", "1/2-1/2"
  whitePlayer   Player      @relation("WhiteMatchPlayer", fields: [whitePlayerId], references: [id])
  blackPlayer   Player      @relation("BlackMatchPlayer", fields: [blackPlayerId], references: [id])
}

enum GameType {
  CLASSICAL
  RAPID
  BLITZ
}

model LeagueStanding {
  id          String @id @default(cuid())
  rank        Int
  clubId      String
  club        Club   @relation(fields: [clubId], references: [id])
  played      Int    @default(0)
  won         Int    @default(0)
  drawn       Int    @default(0)
  lost        Int    @default(0)
  matchPoints Int
  gamePoints  Float
  tiebreak1   Float  @default(0)
  tiebreak2   Float  @default(0)
  tiebreak3   Float  @default(0)
}

model Tournament {
  id                   String           @id @default(cuid())
  name                 String
  description          String?
  history              String?
  startDate            DateTime
  endDate            DateTime
  registrationDeadline DateTime?
  registrationFee      Float?
  prizeFund            Float?
  venue                String?
  format               String           @default("Swiss") // Swiss, Round-Robin
  totalRounds          Int
  isGrandPrix          Boolean          @default(false)
  sponsors             Sponsor[]
  officials            Official[]
  players              Player[]
  games                Game[]
  scores               Score[]
  pairings             Pairing[]
  grandPrixPoints      GrandPrixPoint[]
}

model GrandPrixPoint {
  id           String     @id @default(cuid())
  points       Float
  playerId     String
  tournamentId String
  player       Player     @relation(fields: [playerId], references: [id])
  tournament   Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([playerId, tournamentId])
}

model Sponsor {
  id           String       @id @default(cuid())
  name                 String
  logoUrl      String?
  tournaments  Tournament[]
}

model Official {
  id           String       @id @default(cuid())
  name         String
  role         String       // Arbiter, Organizer, etc.
  tournaments  Tournament[]
}

model Game {
  id           String     @id @default(cuid())
  tournamentId String
  round        Int
  whiteId      String
  blackId      String
  result       String?    // "1-0", "0-1", "1/2-1/2"
  pgn          String?
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  white        Player     @relation("white_games", fields: [whiteId], references: [id])
  black        Player     @relation("black_games", fields: [blackId], references: [id])
}

model Score {
  id           String     @id @default(cuid())
  tournamentId String
  playerId     String
  score        Float
  buchholz     Float?
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  player       Player     @relation(fields: [playerId], references: [id])
}

model Pairing {
  id           String     @id @default(cuid())
  round        Int
  table        Int
  whiteId      String
  blackId      String
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
}
